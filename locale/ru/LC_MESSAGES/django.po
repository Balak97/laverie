msgstr "Ваш профиль успешно обновлён."

msgid "Please correct the errors in the form."
msgstr "Исправьте ошибки в форме."

msgid "Your password has been changed successfully."
msgstr "Пароль успешно изменён."

msgid "Account locked"
msgstr "Аккаунт заблокирован"

msgid "Too many login attempts have been made."
msgstr "Слишком много попыток входа."

msgid "Your account or IP address is temporarily locked."
msgstr "Ваш аккаунт или IP-адрес временно заблокированы."

msgid "Please try again later."
msgstr "Попробуйте позже."

msgid "Back to login page"
msgstr "Вернуться на страницу входа"

msgid "User list"
msgstr "Список пользователей"

msgid "Promote users to couriers"
msgstr "Назначить пользователей курьерами"

msgid "Users register as clients. You can promote them to couriers. Once promoted, they can be assigned to packed orders."
msgstr "Пользователи регистрируются как клиенты. Вы можете назначить их курьерами. После назначения им можно поручать собранные заказы."

msgid "Registered on"
msgstr "Зарегистрирован"

msgid "Promote to courier"
msgstr "Назначить курьером"

msgid "No client users available"
msgstr "Нет доступных пользователей-клиентов"

msgid "Email verification"
msgstr "Подтверждение email"

msgid "Check your mailbox..."
msgstr "Проверьте почту..."

msgid "We have sent you an activation link."
msgstr "Мы отправили вам ссылку для активации."

msgid "Please click it to complete your registration."
msgstr "Нажмите на неё, чтобы завершить регистрацию."

msgid "Resend activation link"
msgstr "Отправить ссылку активации повторно"

msgid "Your email address"
msgstr "Ваш email"

msgid "Resend link"
msgstr "Отправить ссылку снова"

msgid "Account activated"
msgstr "Аккаунт активирован"

msgid "Your account has been successfully activated! You will be redirected to the login page in 5 seconds."
msgstr "Ваш аккаунт успешно активирован! Через 5 секунд вы будете перенаправлены на страницу входа."

msgid "Something went wrong"
msgstr "Что-то пошло не так"

msgid "Password reset"
msgstr "Сброс пароля"

msgid "Enter your email address and we will send you a link to reset your password."
msgstr "Введите email — мы отправим вам ссылку для сброса пароля."

msgid "example@email.com"
msgstr "example@email.com"

msgid "Send reset link"
msgstr "Отправить ссылку"

msgid "Back to login"
msgstr "Вернуться к входу"

msgid "Check your inbox and spam folder. The link expires after 24 hours."
msgstr "Проверьте входящие и спам. Ссылка действительна 24 часа."

msgid "Email sent!"
msgstr "Письмо отправлено!"

msgid "If the email address you provided exists in our database, you will shortly receive an email with a reset link."
msgstr "Если такой email есть в нашей базе, вы скоро получите письмо со ссылкой для сброса."

msgid "Click the link in the email to create a new password."
msgstr "Перейдите по ссылке из письма, чтобы задать новый пароль."

msgid "Tip:"
msgstr "Совет:"

msgid "Check your spam or junk folder if you do not receive the email within a few minutes."
msgstr "Проверьте папку «Спам», если письмо не пришло в течение нескольких минут."

msgid "Create a new secure password for your account."
msgstr "Придумайте новый надёжный пароль для аккаунта."

msgid "At least 8 characters"
msgstr "Не менее 8 символов"

msgid "Repeat password"
msgstr "Повторите пароль"

msgid "Reset password"
msgstr "Сбросить пароль"

msgid "Your password must be at least 8 characters and different from your username."
msgstr "Пароль должен быть не менее 8 символов и отличаться от имени пользователя."

msgid "Password reset complete!"
msgstr "Пароль успешно сброшен!"

msgid "Your password has been changed successfully. You can now log in with your new password."
msgstr "Пароль изменён. Теперь вы можете войти с новым паролем."

msgid "Security:"
msgstr "Безопасность:"

msgid "Keep your login details secret and never share them with anyone."
msgstr "Храните данные для входа в секрете и никому их не сообщайте."

msgid "Hello,"
msgstr "Здравствуйте,"

msgid "You are receiving this email because you requested a password reset for your account on Dortoir 3."
msgstr "Вы получили это письмо, так как запросили сброс пароля для аккаунта на Dortoir 3."

msgid "Please click the link below to reset your password:"
msgstr "Нажмите на ссылку ниже, чтобы сбросить пароль:"

msgid "If you did not request this reset, you can ignore this email."
msgstr "Если вы не запрашивали сброс, проигнорируйте это письмо."

msgid "Your password will not be changed until you click the link above and create a new password."
msgstr "Пароль не изменится, пока вы не перейдёте по ссылке и не зададите новый пароль."

msgid "Thank you,"
msgstr "С уважением,"

msgid "The Dortoir 3 team"
msgstr "Команда Dortoir 3"
